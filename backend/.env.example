# ===========================
# Servidor
# ===========================
PORT=5000
NODE_ENV=development

# ===========================
# Base de datos MongoDB
# ===========================
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/lubricentro_eden?retryWrites=true&w=majority

# ===========================
# JWT
# ===========================
JWT_SECRET=cambia_este_secreto_super_seguro_1234567890
JWT_EXPIRES_IN=7d

# ===========================
# Mercado Pago
# ===========================
MP_ACCESS_TOKEN=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MP_WEBHOOK_SECRET=tu_webhook_secret

# ===========================
# Frontend (CORS)
# ===========================
FRONTEND_URL=http://localhost:5173

# ===========================
# Upload
# ===========================
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads/

# ===========================
# Andreani (Envíos)
# ===========================
# Credenciales de cliente Andreani (developers.andreani.com)
ANDREANI_USER=
ANDREANI_PASS=
ANDREANI_CONTRACT=
# URL base de la API (producción)
ANDREANI_API_URL=https://apis.andreani.com
# Código postal de origen del local (Córdoba capital = 5000)
ANDREANI_ORIGIN_CP=5000
# Monto mínimo para envío GRATIS (en ARS)
FREE_SHIPPING_THRESHOLD=70000
